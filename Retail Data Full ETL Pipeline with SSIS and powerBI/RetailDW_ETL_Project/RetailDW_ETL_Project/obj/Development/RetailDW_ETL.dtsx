        <SQLTask:SqlTaskData
          SQLTask:Connection="{C675C0D6-ADF1-4E3D-8A01-A8F6C8ACEF24}"
          SQLTask:SqlStatementSource="SELECT&#xA;    (SELECT COUNT(*) FROM stg_Customers) AS StagingCustomers,&#xA;    (SELECT COUNT(*) FROM stg_Products) AS StagingProducts,&#xA;    (SELECT COUNT(*) FROM stg_Orders) AS StagingOrders,&#xA;    (SELECT COUNT(*) FROM DimCustomers) AS DimCustomers,&#xA;    (SELECT COUNT(*) FROM DimProducts) AS DimProducts,&#xA;    (SELECT COUNT(*) FROM DimDate) AS DimDates,&#xA;    (SELECT COUNT(*) FROM FactSales) AS FactSalesRows;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
