    <DTS:Executable
      DTS:refId="Package\Load DimCustomer"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3791734E-A2AE-4CA8-AAC6-89A4D8EB2290}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimCustomer"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C675C0D6-ADF1-4E3D-8A01-A8F6C8ACEF24}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.DimCustomers (&#xA;    CustomerID,&#xA;    City,&#xA;    AgeGroup,&#xA;    SignupDate&#xA;)&#xA;SELECT DISTINCT&#xA;    CustomerID,&#xA;    City,&#xA;    AgeGroup,&#xA;    SignupDate&#xA;FROM dbo.stg_Customers&#xA;WHERE CustomerID NOT IN (&#xA;    SELECT CustomerID FROM dbo.DimCustomers&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{239E1369-568C-45C7-A651-8D2080DC1ECD}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C675C0D6-ADF1-4E3D-8A01-A8F6C8ACEF24}"
          SQLTask:SqlStatementSource="INSERT INTO DimDate (&#xA;    DateKey,&#xA;    FullDate,&#xA;    [Year],&#xA;    [Month],&#xA;    MonthName,&#xA;    [Quarter],&#xA;    DayOfMonth,&#xA;    DayName&#xA;)&#xA;SELECT DISTINCT&#xA;    CONVERT(INT, FORMAT(OrderDate, 'yyyyMMdd')) AS DateKey,&#xA;    OrderDate AS FullDate,&#xA;    YEAR(OrderDate) AS [Year],&#xA;    MONTH(OrderDate) AS [Month],&#xA;    DATENAME(MONTH, OrderDate) AS MonthName,&#xA;    DATEPART(QUARTER, OrderDate) AS [Quarter],&#xA;    DAY(OrderDate) AS DayOfMonth,&#xA;    DATENAME(WEEKDAY, OrderDate) AS DayName&#xA;FROM stg_Orders&#xA;WHERE CONVERT(INT, FORMAT(OrderDate, 'yyyyMMdd')) NOT IN (&#xA;    SELECT DateKey FROM DimDate&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimProduct"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{364120A1-A672-4FCB-9855-32C6ACC8582E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimProduct"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C675C0D6-ADF1-4E3D-8A01-A8F6C8ACEF24}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.DimProducts (&#xA;    ProductID,&#xA;    Category,&#xA;    ListPrice,&#xA;    Cost&#xA;)&#xA;SELECT DISTINCT&#xA;    ProductID,&#xA;    Category,&#xA;    ListPrice,&#xA;    Cost&#xA;FROM dbo.stg_Products&#xA;WHERE ProductID NOT IN (&#xA;    SELECT ProductID FROM dbo.DimProducts&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load FactSales"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{CD7640A4-ED70-4C5F-BF7C-B2CFCD392A1E}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactSales"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C675C0D6-ADF1-4E3D-8A01-A8F6C8ACEF24}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.FactSales (&#xA;    OrderID,&#xA;    CustomerKey,&#xA;    ProductKey,&#xA;    DateKey,&#xA;    Quantity,&#xA;    Revenue,&#xA;    TotalCost,&#xA;    Profit,&#xA;    Channel&#xA;)&#xA;SELECT&#xA;    o.OrderID,&#xA;    c.CustomerKey,&#xA;    p.ProductKey,&#xA;    d.DateKey,&#xA;    o.Quantity,&#xA;    o.Quantity * p.ListPrice AS Revenue,&#xA;    o.Quantity * p.Cost AS TotalCost,&#xA;    o.Quantity * (p.ListPrice - p.Cost) AS Profit,&#xA;    o.Channel&#xA;FROM dbo.stg_Orders o&#xA;JOIN dbo.DimCustomers c&#xA;    ON o.CustomerID = c.CustomerID&#xA;JOIN dbo.DimProducts p&#xA;    ON o.ProductID = p.ProductID&#xA;JOIN dbo.DimDate d&#xA;    ON o.OrderDate = d.FullDate&#xA;WHERE o.OrderID NOT IN (&#xA;    SELECT OrderID FROM dbo.FactSales&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
